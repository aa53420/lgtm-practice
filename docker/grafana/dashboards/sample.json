{
  "title": "LGTM Practice Dashboard",
  "panels": [
    {
      "id": 1,
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "CPU 사용량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "process_cpu_usage{job=\"spring-boot\"} * 100",
          "legendFormat": "Process CPU"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "system_cpu_usage{job=\"spring-boot\"} * 100",
          "legendFormat": "System CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    }
  ]
}

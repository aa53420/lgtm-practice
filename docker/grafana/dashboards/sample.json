{
  "title": "LGTM Practice Dashboard",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "collapsed": false,
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "process_uptime_seconds{job=\"spring-boot\"}",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Live Threads",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "jvm_threads_live_threads{job=\"spring-boot\"}",
          "legendFormat": "Threads"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Process CPU",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "process_cpu_usage{job=\"spring-boot\"} * 100",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 6,
      "type": "row",
      "collapsed": false,
      "title": "CPU & Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU 사용량",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "process_cpu_usage{job=\"spring-boot\"} * 100",
          "legendFormat": "Process CPU"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "system_cpu_usage{job=\"spring-boot\"} * 100",
          "legendFormat": "System CPU"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "JVM Heap Memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "jvm_memory_used_bytes{job=\"spring-boot\", area=\"heap\"}",
          "legendFormat": "{{id}} Used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(jvm_memory_used_bytes{job=\"spring-boot\", area=\"heap\"})",
          "legendFormat": "Total Used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "jvm_memory_committed_bytes{job=\"spring-boot\", area=\"heap\"}",
          "legendFormat": "{{id}} Committed"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(jvm_memory_committed_bytes{job=\"spring-boot\", area=\"heap\"})",
          "legendFormat": "Total Committed"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 9,
      "type": "row",
      "collapsed": false,
      "title": "HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP 요청 처리율 (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot\"}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP 5xx 에러율",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot\", status=~\"5..\"}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 12,
      "type": "row",
      "collapsed": false,
      "title": "Traces",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "id": 13,
      "type": "nodeGraph",
      "title": "Service Map",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "serviceMap",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "traces",
      "title": "Trace 검색",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "expr": "{}",
          "limit": 20,
          "refId": "A"
        }
      ]
    }
  ]
}
